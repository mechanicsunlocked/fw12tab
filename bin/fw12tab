#!/bin/bash
# fw12tab — Framework 12 tablet mode for Omarchy / Hyprland.
#
#   setup          Wire up Hyprland config (run once, as your normal user)
#   rotate-toggle  Toggle auto-rotation on/off (bound to Super+R)
#   osk-toggle     Show/hide the on-screen keyboard (oskbd)
#   autorotate     Event-driven rotation daemon (exec-once) — ~0% idle CPU
#   tablet-watch   Tablet-mode watcher off SW_TABLET_MODE (exec-once) — 0% idle
#   doctor         Print diagnostics
#
# Debug: FW12TAB_DEBUG=1 logs to stderr. Tunables: FW12TAB_OSK_HEIGHT (px),
# FW12TAB_TABLET_BIN (SW_TABLET_MODE reader path).
# Inspired by https://github.com/2disbetter/FW12Rotate
set -u

STATE_FILE="${FW12TAB_STATE:-$HOME/.config/hypr/fw12tab-rotation-enabled}"
ORIENT_CACHE="${XDG_RUNTIME_DIR:-/tmp}/fw12tab-orientation"
TABLET_FLAG="${XDG_RUNTIME_DIR:-/tmp}/fw12tab-tablet"   # 1 = in tablet mode
OSK_BUTTON="${FW12TAB_OSK_BUTTON:-/usr/lib/fw12tab/osk-button}"
TABLET_BIN="${FW12TAB_TABLET_BIN:-/usr/lib/fw12tab/tabletmode}"   # SW_TABLET_MODE reader (C)
CONF="/usr/share/fw12tab/fw12tab.conf"

# On-screen keyboard: fw12tab's own GTK4 layer-shell keyboard (oskbd). It mirrors
# the FW12 physical layout and uploads the real xkb keymap, so it types exactly
# like the built-in keyboard. Process name 'oskbd'; manage with pgrep/pkill -x.
OSKBD_BIN="${FW12TAB_OSKBD:-/usr/lib/fw12tab/oskbd}"

# Detect the active keyboard layout/variant (Hyprland input.conf, else localectl,
# else 'us') so oskbd's keymap + key labels match the physical keyboard.
_kb_layout() {
  local lay var
  lay=$(grep -E '^[[:space:]]*kb_layout' "$HOME/.config/hypr/input.conf" 2>/dev/null \
        | head -1 | sed -E 's/.*=[[:space:]]*//; s/[[:space:]]*(#.*)?$//' | cut -d, -f1)
  var=$(grep -E '^[[:space:]]*kb_variant' "$HOME/.config/hypr/input.conf" 2>/dev/null \
        | head -1 | sed -E 's/.*=[[:space:]]*//; s/[[:space:]]*(#.*)?$//' | cut -d, -f1)
  [ -n "$lay" ] || lay=$(localectl status 2>/dev/null | sed -nE 's/.*X11 Layout:[[:space:]]*([^ ,]+).*/\1/p' | head -1)
  printf '%s\t%s' "${lay:-us}" "$var"
}

_dbg()    { [ "${FW12TAB_DEBUG:-0}" = 1 ] && printf '[fw12tab %s] %s\n' "$(date +%T)" "$*" >&2; return 0; }
_notify() { command -v notify-send >/dev/null 2>&1 && notify-send -i input-tablet "fw12tab" "$1"; return 0; }
_have()   { command -v "$1" >/dev/null 2>&1; }

# --- rotation (event-driven via iio-sensor-proxy / monitor-sensor) ----------
_panel() {  # internal panel (eDP*), else first monitor
  hyprctl monitors -j 2>/dev/null \
    | jq -r 'map(.name)|((map(select(test("eDP")))|first) // .[0]) // empty' 2>/dev/null
}
_scale()     { hyprctl monitors -j 2>/dev/null | jq -r --arg m "$1" '.[]|select(.name==$m)|.scale' 2>/dev/null; }
_transform() { case "$1" in normal) echo 0;; left-up) echo 1;; bottom-up) echo 2;; right-up) echo 3;; *) echo -1;; esac; }
# Master switch (Super+R). Default ON: a missing/empty file means enabled, so
# auto-rotation works out of the box — it still only acts in tablet mode.
_enabled()     { [ "$(cat "$STATE_FILE" 2>/dev/null || echo 1)" != 0 ]; }
_tablet_mode() { [ "$(cat "$TABLET_FLAG" 2>/dev/null)" = 1 ]; }

_set_transform() {  # $1 = transform int — drive panel + touch + tablet input
  local mon sc; mon=$(_panel); [ -n "$mon" ] || { _dbg "no monitor"; return 0; }
  sc=$(_scale "$mon"); { [ -n "$sc" ] && [ "$sc" != null ]; } || sc=1
  hyprctl keyword monitor "$mon, preferred, auto, $sc, transform, $1" >/dev/null 2>&1
  hyprctl keyword input:touchdevice:transform "$1" >/dev/null 2>&1
  hyprctl keyword input:tablet:transform "$1" >/dev/null 2>&1
}
_reset_rotation() { _dbg "reset to landscape"; _set_transform 0; }

_apply() {  # $1 = orientation
  printf '%s' "$1" > "$ORIENT_CACHE" 2>/dev/null
  _enabled || return 0
  _tablet_mode || return 0   # gate: rotate ONLY in tablet mode (like GNOME/Windows)
  local t; t=$(_transform "$1"); [ "$t" -ge 0 ] 2>/dev/null || { _dbg "unknown orientation '$1'"; return 0; }
  _dbg "apply $1 -> transform $t"
  _set_transform "$t"
}

cmd_autorotate() {
  _have monitor-sensor || { echo "fw12tab: iio-sensor-proxy (monitor-sensor) missing" >&2; exit 1; }
  printf normal > "$ORIENT_CACHE" 2>/dev/null
  local line o
  while :; do  # reconnect if monitor-sensor dies (e.g. proxy restart)
    while IFS= read -r line; do
      case "$line" in
        *"orientation changed: "*) o=${line##*orientation changed: } ;;
        *"(orientation: "*)        o=${line##*(orientation: } ;;
        *) continue ;;
      esac
      o=${o%%[, )]*}   # keep only the orientation token (drop trailing tilt/paren)
      _apply "$o"
    done < <(stdbuf -oL monitor-sensor 2>/dev/null)
    _dbg "monitor-sensor exited; retrying"; sleep 2
  done
}

cmd_rotate_toggle() {
  local s; s=$(cat "$STATE_FILE" 2>/dev/null); [[ "$s" =~ ^[01]$ ]] || s=1   # default ON
  if [ "$s" = 1 ]; then echo 0 > "$STATE_FILE"; _notify "Auto-rotation disabled"; _reset_rotation
  else echo 1 > "$STATE_FILE"; _notify "Auto-rotation enabled"; _apply "$(cat "$ORIENT_CACHE" 2>/dev/null || echo normal)"; fi
}

# --- on-screen keyboard (oskbd) ---------------------------------------------
# The toggle button is a small C/GTK4 layer-shell binary (osk-button).
_osk_launch() {
  [ -x "$OSK_BUTTON" ] || return 1
  setsid -f "$OSK_BUTTON" >/dev/null 2>&1
}
_osk_button_up() {  # spawn only if not already running (tablet entry)
  pgrep -x osk-button >/dev/null 2>&1 || _osk_launch
}
_osk_button_restack() {  # force the button to be the newest overlay -> on top
  pkill -x osk-button 2>/dev/null; sleep 0.3; _osk_launch
}

cmd_osk_toggle() {
  if pgrep -x oskbd >/dev/null 2>&1; then pkill -x oskbd; return; fi
  [ -x "$OSKBD_BIN" ] || { _notify "keyboard not installed (oskbd)"; exit 1; }
  local lay var; IFS=$'\t' read -r lay var < <(_kb_layout)
  setsid -f "$OSKBD_BIN" "$lay" "$var" "" >/dev/null 2>&1
  # oskbd is on the TOP layer; the osk-button is OVERLAY, so it already floats
  # above it and stays tappable to toggle the keyboard back off.
}

# --- tablet-mode watcher (SW_TABLET_MODE switch) ----------------------------
# The FW12 EC exposes a real SW_TABLET_MODE switch (INT33D3 gpio-keys) — the
# same signal GNOME/Windows gate tablet mode on. The C reader (tabletmode)
# streams 1/0 on every change, so this is fully event-driven: no polling, no
# 500-angle ambiguity, and it survives suspend/resume. Firmware sets the hinge
# thresholds (~200° enter, ~100° exit) — they are not tunable.
cmd_tablet_watch() {
  local st
  [ -x "$TABLET_BIN" ] || { echo "fw12tab: tablet-mode reader missing: $TABLET_BIN" >&2; exit 1; }
  _dbg "watching SW_TABLET_MODE via $TABLET_BIN"
  # The watcher owns the button + the rotation gate; start from a clean laptop.
  pkill -x osk-button 2>/dev/null; printf 0 > "$TABLET_FLAG" 2>/dev/null
  while :; do   # reconnect if the reader exits (device hotplug / resume)
    while IFS= read -r st; do
      case "$st" in
        1) _dbg "tablet (SW_TABLET_MODE=1)"
           printf 1 > "$TABLET_FLAG" 2>/dev/null     # open the rotation gate first
           _osk_button_up
           _apply "$(cat "$ORIENT_CACHE" 2>/dev/null || echo normal)" ;;  # catch up to tilt
        0) _dbg "laptop (SW_TABLET_MODE=0)"
           printf 0 > "$TABLET_FLAG" 2>/dev/null     # close the gate, back to landscape
           pkill -x osk-button 2>/dev/null; pkill -x oskbd 2>/dev/null
           _reset_rotation ;;
      esac
    done < <("$TABLET_BIN" 2>/dev/null)
    _dbg "tablet reader exited; retrying"; sleep 2
  done
}

# --- setup / doctor ---------------------------------------------------------
cmd_setup() {
  local hypr="$HOME/.config/hypr/hyprland.conf"
  mkdir -p "$HOME/.config/hypr"; [ -f "$STATE_FILE" ] || echo 1 > "$STATE_FILE"
  if [ -f "$hypr" ] && grep -qF "fw12tab/fw12tab.conf" "$hypr"; then echo "Already wired up."
  else printf '\n# fw12tab\nsource = %s\n' "$CONF" >> "$hypr"; echo "Added source line to $hypr"; fi
  if [ -f "$hypr" ] && grep -qiE '^[[:space:]]*(bind|exec-once)[^#]*(FW12Rotate|rotation-toggle|toggle-rotation\.sh)' "$hypr"; then
    echo "WARNING: old FW12Rotate lines found in $hypr — remove its 'bind = SUPER, R' and"
    echo "         'exec-once = .../FW12Rotate' lines to avoid a Super+R clash."
  fi
  _have hyprctl && hyprctl reload >/dev/null 2>&1
  echo "Done. Super+R toggles rotation; fold into tablet posture for the keyboard button."
}

cmd_doctor() {
  local rc=0 b mon
  echo "fw12tab doctor"
  for b in hyprctl jq monitor-sensor notify-send; do
    if _have "$b"; then echo "  [ok] $b"; else echo "  [MISSING] $b"; rc=1; fi
  done
  if [ -x "$TABLET_BIN" ]; then echo "  [ok] tablet switch reader (C): $TABLET_BIN"
  else echo "  [MISSING] $TABLET_BIN (run install.sh / rebuild)"; rc=1; fi
  mon=$(_panel)
  echo "  panel: ${mon:-?} (scale $(_scale "$mon"))"
  echo "  rotation: $(_enabled && echo enabled || echo disabled) (only acts in tablet mode); mode: $(_tablet_mode && echo tablet || echo laptop); orientation: $(cat "$ORIENT_CACHE" 2>/dev/null || echo n/a)"
  pgrep -f "fw12tab autorotate"   >/dev/null 2>&1 && echo "  [ok] autorotate running"   || echo "  [--] autorotate not running"
  pgrep -f "fw12tab tablet-watch" >/dev/null 2>&1 && echo "  [ok] tablet-watch running" || echo "  [--] tablet-watch not running"
  grep -qF "fw12tab/fw12tab.conf" "$HOME/.config/hypr/hyprland.conf" 2>/dev/null \
    && echo "  [ok] Hyprland sources fw12tab.conf" || echo "  [--] not wired up (run: fw12tab setup)"
  [ -x "$OSK_BUTTON" ] && echo "  [ok] osk-button (C): $OSK_BUTTON" || { echo "  [MISSING] $OSK_BUTTON"; rc=1; }
  if [ -x "$OSKBD_BIN" ]; then
    local lay var; IFS=$'\t' read -r lay var < <(_kb_layout)
    echo "  [ok] keyboard (C/GTK4): $OSKBD_BIN — layout ${lay}${var:+($var)}"
  else echo "  [MISSING] $OSKBD_BIN"; rc=1; fi
  return $rc
}

case "${1:-}" in
  setup) cmd_setup ;; rotate-toggle) cmd_rotate_toggle ;; osk-toggle) cmd_osk_toggle ;;
  autorotate) cmd_autorotate ;; tablet-watch) cmd_tablet_watch ;; doctor) cmd_doctor ;;
  ""|-h|--help|help)
    sed -n '2,9p' "$0" | sed 's/^# \{0,1\}//' ;;
  *) echo "fw12tab: unknown command '$1'" >&2; exit 1 ;;
esac
